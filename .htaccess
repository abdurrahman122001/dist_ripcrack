# Content Security Policy for Chat Widget
<IfModule mod_headers.c>
    Header always set Content-Security-Policy "default-src 'self' 'unsafe-inline' 'unsafe-eval'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://static.cloudflareinsights.com https://challenges.cloudflare.com https://chat.ripcrack.net https://ripcrack.net https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline'; connect-src 'self' https://api.chatmesaj.cc https://chat.ripcrack.net ws: wss:; img-src 'self' data: https://chat.ripcrack.net https://api.chatmesaj.cc; frame-src 'self' https://chat.ripcrack.net; font-src 'self' data:;"
</IfModule>

# Enable CORS for API requests
<IfModule mod_headers.c>
    Header always set Access-Control-Allow-Origin "*"
    Header always set Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
    Header always set Access-Control-Allow-Headers "Content-Type, Authorization"
</IfModule>
